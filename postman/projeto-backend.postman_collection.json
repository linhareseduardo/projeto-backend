            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "user", "{{userId}}"]
            }
          }
        }
      ]
    },
