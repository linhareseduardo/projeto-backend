{
  "info": {
    "_postman_id": "c5f0e30d-2f26-4b84-b944-69c6c7a6a001",
    "name": "Projeto Backend - Demo",
    "description": "Colecao para demonstracao do backend (health, token, usuarios, categorias, produtos).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "seedEmail", "value": "seed.user.0.1@mail.com" },
    { "key": "seedPassword", "value": "123@123" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /v1/user/token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{seedEmail}}\",\n  \"password\": \"{{seedPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/user/token",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "user", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /v1/user/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "user", "{{userId}}"]
            }
          }
        },
        {
          "name": "POST /v1/user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Demo\",\n  \"surname\": \"User\",\n  \"email\": \"demo.user.{{$timestamp}}@mail.com\",\n  \"password\": \"123@123\",\n  \"confirmPassword\": \"123@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/user",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "user"]
            }
          }
        },
        {
          "name": "PUT /v1/user/:id",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
