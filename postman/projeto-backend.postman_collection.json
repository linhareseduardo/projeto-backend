            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Demo Atualizado\",\n  \"surname\": \"User\",\n  \"email\": \"demo.atualizado@mail.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "user", "{{userId}}"]
            }
          }
        },
        {
          "name": "DELETE /v1/user/:id",
